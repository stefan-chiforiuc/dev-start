{
  "Auth": {
    "Authority": "http://localhost:8080/realms/devstart",
    "Audience": "devstart-api"
  },
  "ReverseProxy": {
    "Routes": {
      "users": {
        "ClusterId": "users",
        "Match": { "Path": "/users/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/users" }]
      },
      "orders": {
        "ClusterId": "orders",
        "Match": { "Path": "/orders/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/orders" }]
      }
    },
    "Clusters": {
      "users": {
        "Destinations": { "d1": { "Address": "http://users:5000/" } }
      },
      "orders": {
        "Destinations": { "d1": { "Address": "http://orders:5000/" } }
      }
    }
  }
}
