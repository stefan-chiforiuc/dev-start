{
  "$schema": "https://dev-start.dev/schemas/capability/1.json",
  "name": "cache",
  "version": "0.1.0",
  "description": "Redis distributed cache via IDistributedCache, with a typed wrapper and cache-aside helpers.",
  "dependsOn": ["base"],
  "conflictsWith": [],
  "addsServices": ["redis"],
  "envAdditions": [
    { "key": "Redis__Connection", "example": "localhost:6379" }
  ],
  "postInstall": ["dotnet restore"],
  "doctor": [
    { "check": "service", "name": "redis", "port": 6379 },
    { "check": "env", "name": "Redis__Connection" }
  ]
}
