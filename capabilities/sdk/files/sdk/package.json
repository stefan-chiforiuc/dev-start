{
  "name": "@{{name}}/sdk",
  "version": "0.1.0",
  "description": "Typed client for the {{Name}} API, generated from OpenAPI.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "openapi-typescript ../src/{{Name}}.Api/openapi.json -o src/schema.d.ts",
    "build": "npm run generate && tsc -p tsconfig.json",
    "check": "npm run generate && git diff --exit-code -- src/schema.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "files": [
    "dist",
    "src/schema.d.ts"
  ],
  "license": "MIT"
}
