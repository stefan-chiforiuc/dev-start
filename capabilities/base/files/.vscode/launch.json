{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "{{Name}}.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/{{Name}}.Api/bin/Debug/net8.0/{{Name}}.Api.dll",
      "cwd": "${workspaceFolder}/src/{{Name}}.Api",
      "stopAtEntry": false,
      "console": "internalConsole",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5000"
      },
      "serverReadyAction": {
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/docs",
        "action": "openExternally"
      }
    }
  ]
}
