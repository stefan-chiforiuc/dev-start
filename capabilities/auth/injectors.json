{
  "injectors": [
    {
      "file": "src/{{Name}}.Api/{{Name}}.Api.csproj",
      "anchor": "</Project>",
      "placement": "before",
      "fragment": "api.csproj.fragment"
    },
    {
      "file": "src/{{Name}}.Api/DependencyInjection.cs",
      "marker": "// devstart:api-services",
      "placement": "after",
      "fragment": "api-services.fragment"
    },
    {
      "file": "src/{{Name}}.Api/DependencyInjection.cs",
      "marker": "// devstart:api-endpoints",
      "placement": "after",
      "fragment": "api-endpoints.fragment"
    },
    {
      "file": "src/{{Name}}.Api/Program.cs",
      "marker": "// devstart:program-before-middleware",
      "placement": "after",
      "fragment": "program-middleware.fragment"
    },
    {
      "file": "src/{{Name}}.Api/appsettings.json",
      "anchor": "\"AllowedHosts\": \"*\"",
      "placement": "before",
      "fragment": "appsettings-auth.json.fragment"
    }
  ]
}
